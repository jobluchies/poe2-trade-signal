# Copy to .env and fill in. .env is gitignored.

# Target league (display name exactly as poe.ninja's index-state reports it).
# Confirmed 2026-06-17: "HC Runes of Aldur". The fetcher validates this against
# index-state at runtime and warns if it has rotated.
POE2_LEAGUE=HC Runes of Aldur

# League start (UTC ISO 8601). Used to derive league_day for cross-league overlays.
# Runes of Aldur launched 2026-05-29 20:00 UTC. VERIFY against the live site.
POE2_LEAGUE_START=2026-05-29T20:00:00Z

# --- Layer D (community scrape) — NOT used in Phase 1-3, here for later ---
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# YOUTUBE_API_KEY=
